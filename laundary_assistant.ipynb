# --- HSV BASELINE & COMPARISON CELL ---
# 1. HSV Classifier (from utils.py)
# H (0-179), S (0-255), V (0-255)
HSV_RANGES = {
    # Dark: Low V (Brightness)
    "DARK": {"lower": np.array([0, 0, 0]), "upper": np.array([179, 255, 60])},
    # Light: Low S (Saturation) and High V (Brightness)
    "LIGHT": {"lower": np.array([0, 0, 180]), "upper": np.array([179, 40, 255])},
    # Colored: Mid S and Mid V (Everything else with defined color)
    "COLORED": {"lower": np.array([0, 40, 60]), "upper": np.array([179, 255, 180])}
}

def classify_hsv(image_path):
    # Load and resize (to match CNN input processing)
    img_bgr = cv2.imread(image_path)
    if img_bgr is None: return "ERROR", 0.0
    img_bgr = cv2.resize(img_bgr, (64, 64))
    img_hsv = cv2.cvtColor(img_bgr, cv2.COLOR_BGR2HSV)
    
    max_score = 0
    predicted_class = "UNKNOWN"
    total_pixels = img_bgr.shape[0] * img_bgr.shape[1]

    for name, limits in HSV_RANGES.items():
        mask = cv2.inRange(img_hsv, limits["lower"], limits["upper"])
        pixel_count = cv2.countNonZero(mask)
        proportion = pixel_count / total_pixels
        
        # Simple Max-proportion decision rule
        if proportion > max_score:
            max_score = proportion
            predicted_class = name
            
    return predicted_class, max_score

# 2. Comparison/Inference Function
def final_comparison_demo(image_path, cnn_model):
    # CNN Inference (Requires model to be trained/loaded)
    try:
        cnn_model.eval()
        img_pil = PImage.open(image_path).convert('RGB')
        
        # Use validation transform for inference
        input_tensor = data_transforms['val'](img_pil).unsqueeze(0).to(device)
        
        with torch.no_grad():
            output = cnn_model(input_tensor)
            _, predicted = torch.max(output.data, 1)
        
        cnn_pred = CLASS_NAMES[predicted.item()]
        
    except Exception as e:
        cnn_pred = f"CNN Error: {e}"

    # HSV Prediction
    hsv_pred, hsv_score = classify_hsv(image_path)
    
    # Visualization
    img_bgr = cv2.imread(image_path)
    plt.imshow(cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB))
    plt.title(f"Image: {os.path.basename(image_path)}\nHSV Prediction: {hsv_pred} | CNN Prediction: {cnn_pred}")
    plt.axis('off')
    plt.show()
    
    print("-" * 30)
    print(f"HSV Result: {hsv_pred} (Score: {hsv_score:.2f})")
    print(f"CNN Result: {cnn_pred}")
    print("-" * 30)
    
