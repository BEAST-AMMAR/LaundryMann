# --- CNN MODEL DEFINITION CELL (from models.py) ---
class SimpleLaundryCNN(nn.Module):
    def __init__(self, num_classes=3):
        super(SimpleLaundryCNN, self).__init__()
        # Input: 3x64x64
        self.conv1 = nn.Conv2d(3, 16, kernel_size=3, padding=1)
        self.pool = nn.MaxPool2d(kernel_size=2, stride=2)
        self.conv2 = nn.Conv2d(16, 32, kernel_size=3, padding=1)
        self.conv3 = nn.Conv2d(32, 64, kernel_size=3, padding=1)
        
        # Output size after 3 conv/pool layers: 64x64 -> 32x32 -> 16x16 -> 8x8.
        # Wait, 3 layers of pooling reduces 64x64 to 8x8. Let's use 2 layers for simplicity.
        # 64x64 -> 32x32 (pool 1) -> 16x16 (pool 2) 
        
        # Recalculating output size after 2 pool layers for 64x64 input: 
        # (64/2)/2 = 16. Final map size: 16x16.
        self.fc1 = nn.Linear(32 * 16 * 16, 128) # Adjusted for 64x64 input with 2 pool layers
        self.fc2 = nn.Linear(128, num_classes)

    def forward(self, x):
        x = self.pool(F.relu(self.conv1(x))) # 64x64 -> 32x32
        x = self.pool(F.relu(self.conv2(x))) # 32x32 -> 16x16
        # x = self.pool(F.relu(self.conv3(x))) # Remove one pool layer for 64x64 input
        
        x = torch.flatten(x, 1) # Flatten (Batch_size, 32*16*16)
        x = F.relu(self.fc1(x))
        x = self.fc2(x)
        return x

# Instantiate model
cnn_model = SimpleLaundryCNN(num_classes=len(CLASS_NAMES)).to(device)
criterion = nn.CrossEntropyLoss()
optimizer = optim.Adam(cnn_model.parameters(), lr=0.001)

